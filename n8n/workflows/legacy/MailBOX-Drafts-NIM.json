        "id": "48855827-cbbb-456d-9caa-7ebb435e83db",
        "name": "Merge Draft"
      },
      {
        "parameters": {
          "method": "POST",
          "url": "https://integrate.api.nvidia.com/v1/chat/completions",
          "authentication": "genericCredentialType",
          "genericAuthType": "httpHeaderAuth",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={\n  \"model\": \"meta/llama-3.3-70b-instruct\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": {{ JSON.stringify(`You are a professional email assistant for ${$json.to_addr}. You write clear, concise, polite reply drafts.\n\nGuidelines:\n- Match the formality of the incoming email\n- Keep responses focused and actionable\n- If commitments are needed, propose specifics (dates, deliverables)\n- If clarification is needed, ask one specific question\n- Never invent facts about the recipient's calendar, prior commitments, or relationships\n- Sign off with the recipient's first name from the email address\n- Do NOT include subject lines — only body text\n- Do NOT include \"Best regards\" boilerplate unless contextually warranted`) }}\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify(`Draft a reply to this email.\n\nFrom: ${$json.from_addr}\nSubject: ${$json.subject}\nReceived: ${$json.received_at}\n\nBody:\n${$json.body}`) }}\n    }\n  ],\n  \"max_tokens\": 500,\n  \"temperature\": 0.7,\n  \"stream\": false\n}",
          "options": {
            "timeout": 60000
          }
        },
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.3,
        "position": [
          320,
          0
        ],
        "id": "5d29d4b6-2b18-4c8a-a88a-af275c0eb4e7",
        "name": "Generate Draft (NIM)",
        "credentials": {
          "httpHeaderAuth": {
            "id": "9MVyw1snxpimtA3X",
            "name": "NVIDIA NIM (Header Auth)"
          }
        }
      },
