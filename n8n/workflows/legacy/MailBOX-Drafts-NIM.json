      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT \n  id,\n  message_id,\n  thread_id,\n  from_addr,\n  to_addr,\n  subject,\n  received_at,\n  body,\n  classification,\n  confidence\nFROM mailbox.inbox_messages\nWHERE classification = 'action_required'\n  AND draft_id IS NULL\nORDER BY received_at DESC\nLIMIT 5;",
          "options": {}
        },
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.6,
        "position": [
          160,
          0
        ],
