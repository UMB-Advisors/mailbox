{
  "name": "mailbox-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx migrations/runner.ts",
    "qdrant:bootstrap": "tsx scripts/qdrant-bootstrap.ts",
    "rag:backfill": "tsx scripts/rag-backfill.ts",
    "db:codegen": "bash scripts/codegen-db.sh",
    "db:codegen:verify": "bash scripts/codegen-db.sh --verify",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "kysely": "^0.28.16",
    "lucide-react": "^0.469.0",
    "next": "14.2.35",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/node": "^20.16.10",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "kysely-codegen": "^0.20.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
