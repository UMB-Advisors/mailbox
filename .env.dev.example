# MailBOX dev environment template (STAQPRO-155).
# Copy to .env.dev and tweak; checked-in defaults are safe for laptops.
#
#   cp .env.dev.example .env.dev
#   docker compose -f docker-compose.dev.yml --env-file .env.dev up -d

# ── Postgres (dev creds; bound to localhost:5432) ──────────────────────
POSTGRES_USER=mailbox
POSTGRES_PASSWORD=mailbox
POSTGRES_DB=mailbox

# ── n8n encryption key ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Dev fallback works but is INSECURE — never use this in prod.
N8N_ENCRYPTION_KEY=dev_only_not_for_prod_replace_me

# ── Optional: Ollama Cloud key for cloud-route drafting in dev ──────────
# Leave empty to test only the local Qwen3 path. Get a key at
# https://ollama.com/cloud.
OLLAMA_CLOUD_API_KEY=
# OLLAMA_CLOUD_MODEL=gpt-oss:120b
