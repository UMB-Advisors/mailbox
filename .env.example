# MailBOX Zero — appliance environment template
# Copy to .env and fill in real values before `docker compose up -d`.
# Variables marked REQUIRED must be set; commented blocks are optional.

# ── Postgres (operational datastore) ────────────────────────────────────
POSTGRES_USER=mailbox
POSTGRES_PASSWORD=changeme_postgres_password   # REQUIRED
POSTGRES_DB=mailbox

# ── n8n (workflow runtime) ──────────────────────────────────────────────
# Encryption key for n8n's stored credentials. Treat as a secret.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme_n8n_encryption_key   # REQUIRED

# ── Caddy (public HTTPS) ────────────────────────────────────────────────
# Public hostname for this appliance (the site address Caddy serves).
# Substituted into the Caddyfile via {$DOMAIN}. Without this, Caddy
# crashes with an empty site address. STAQPRO-237.
DOMAIN=mailbox.example.com   # REQUIRED — your appliance hostname

# Let's Encrypt account email — used for cert expiry warnings.
# Substituted into the Caddyfile global block via {$CADDY_EMAIL}.
# If left empty, certs still issue but you get no expiry warnings.
CADDY_EMAIL=ops@example.com   # REQUIRED for expiry warnings

# Cloudflare API token (DNS-edit scope only) for DNS-01 cert issuance.
# Scope: Zone → DNS → Edit on the chosen zone (NOT account-wide).
# Used by:
#   1. Caddy at runtime for DNS-01 cert solving (substituted into Caddyfile
#      as {env.CLOUDFLARE_API_TOKEN}).
#   2. scripts/provision-customer-dns.sh on the provisioner workstation to
#      create the per-customer A record before first boot (STAQPRO-183).
# Same token, same scope serves both; share via 1Password / out-of-band.
CLOUDFLARE_API_TOKEN=changeme_cloudflare_dns_edit_token   # REQUIRED for public TLS

# Cloudflare zone ID for the Staqs-owned shared subdomain root (e.g. the
# zone covering `staqs.io` if `mailbox.staqs.io` is the shared
# parent — see NC-25 / STAQPRO-183). Only consumed by the provisioning
# script (scripts/provision-customer-dns.sh); Caddy doesn't need it.
# Find at: Cloudflare dashboard → Zone overview → right sidebar "Zone ID".
# Leave blank on customer-owned-domain appliances (e.g. M1 heronlabsinc.com)
# — those don't go through the shared-subdomain provisioner.
CLOUDFLARE_ZONE_ID=                                      # REQUIRED for shared-subdomain provisioner

# Staqs-owned shared subdomain root for customers 2+ (NC-25). Per-customer
# hostnames are <customer-slug>.mailbox.<MAILBOX_SHARED_DOMAIN>. Defaults to
# the value below; locked in as part of the NC-25 rollout (STAQPRO-183).
# Customer #1 (Heron Labs) sits on `mailbox.heronlabsinc.com` and ignores
# this var.
# MAILBOX_SHARED_DOMAIN=staqs.io

# ── Caddy basic_auth (STAQPRO-131) ──────────────────────────────────────
# Gates /dashboard/* and the n8n editor at root behind a single password.
# Generate a bcrypt hash with: docker run --rm caddy:2 caddy hash-password
# If left empty, the Caddyfile blocks proxy unauthenticated (current
# pre-#2 state — DO NOT ship to a 2nd customer like this).
MAILBOX_BASIC_AUTH_USER=admin
MAILBOX_BASIC_AUTH_HASH=

# ── Ollama image (PIN BY DIGEST — STAQPRO-240) ─────────────────────────
# Always pin to a specific digest (sha256), not a moving tag. Upstream
# `ollama/ollama:latest` is a moving target; bumps to a Qwen3-thinking-mode
# release (e.g. 0.23.0) silently broke classification on customer #2 in
# Session 3 of the v0.2 install. The fix shipped in n8n MailBOX-Classify
# (`think: false`) protects against the regression but is not a substitute
# for pinning the runtime.
#
# Capture the live digest on a healthy appliance:
#   docker inspect mailbox-ollama-1 --format '{{.Image}}'
# Then resolve to the repo digest:
#   IID=$(docker inspect mailbox-ollama-1 --format '{{.Image}}')
#   docker inspect "$IID" --format '{{range .RepoDigests}}{{.}}{{println}}{{end}}'
#
# Current customer #1 / #2 baselines (2026-05-07):
#   M1 (Heron Labs): ollama/ollama@sha256:662109db8037f17257cfc6e816289c0d4c9ae8a2a4ff760b653d8d410e234ba0  (0.20.5)
#   M2 (staqs.io):   ollama/ollama@sha256:5600a652d1081050f398152127c584222546354491f27fe47ccbc6351bc870bd  (0.23.0)
#
# For new appliances: pin to whichever validated digest you're cloning from.
# The `dustynv/ollama:0.18.4-r36.4-cu126-22.04` reference in CLAUDE.md
# "Core Technologies" is a documented but unused alternative — the live
# fleet runs upstream `ollama/ollama` images, which work on JetPack 6.2
# with nvidia-container-toolkit configured.
OLLAMA_IMAGE=ollama/ollama@sha256:5600a652d1081050f398152127c584222546354491f27fe47ccbc6351bc870bd

# ── Anthropic (alt-cloud fallback for drafting; not used by default) ────
# 02-07 cloud path now goes through Ollama Cloud — see below.
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Ollama Cloud (cloud-escalation drafting target) ─────────────────────
# Same /api/chat surface as the local Ollama daemon. Used when classify
# routes a message to "cloud" (escalate, low-confidence). Get a key at
# https://ollama.com/cloud. Empty key = cloud path will fail; local-only.
OLLAMA_CLOUD_API_KEY=
# Override base URL or default model if needed:
# OLLAMA_CLOUD_BASE_URL=https://ollama.com
# OLLAMA_CLOUD_MODEL=gpt-oss:120b

# ── RAG retrieval (STAQPRO-191 / 221) ──────────────────────────────────
# Operator's email address — drives the H2 voice-priming retrieval split.
# When set, retrieval runs TWO Qdrant queries in parallel: outbound (from
# MAILBOX_OPERATOR_EMAIL to inbound.from_addr — "how do we write to them") and
# inbound (sender == inbound.from_addr — "what have they said"). When
# unset, retrieval falls back to inbound-only with a warning logged once
# every 30 min. Single-tenant only — multi-persona future state will
# resolve this per-persona from mailbox.persona.
MAILBOX_OPERATOR_EMAIL=

# Optional RAG tunables — defaults below match the live retrieve.ts.
# Top-k cap (merged across inbound+outbound). 3 is the conservative DR-18
# token-budget default; the merge step trims to this ceiling.
# RAG_RETRIEVE_TOP_K=3
# Per-arm split — outbound supplies voice, inbound supplies topical
# history. Inbound at 1 keeps the cheaper-signal arm minimal; outbound
# at 2 prioritizes the H2 voice-priming hypothesis.
# RAG_RETRIEVE_TOP_K_OUTBOUND=2
# RAG_RETRIEVE_TOP_K_INBOUND=1
# Thin-inbound gate (STAQPRO-221 H4). Inbound bodies under N chars after
# quoted-history strip are dropped before embed; the drafter falls back
# to persona-stub. Default 40 catches "ok"/"thx"-style fresh replies
# over long quote chains.
# RAG_MIN_INBOUND_CHARS=40
# Score-floor cutoff (STAQPRO-222 H5). Refs scoring below this threshold
# (cosine, nomic-embed-text:v1.5) are dropped AFTER H1 self-filter, H2
# inbound+outbound merge, H3 same-thread filter, and the topK cap. When
# every hit falls below the floor, retrieve returns reason=below_score_floor
# (distinct from no_hits so eval telemetry can tell them apart). Default
# 0.70 — sweep range 0.60-0.75 per the ticket; tune via eval.
# RAG_MIN_SCORE=0.70
# Same-thread suppression (STAQPRO-222 H3). When set to '1' (default),
# retrieval drops every Qdrant point whose payload.thread_id matches the
# inbound's thread_id, on BOTH the inbound and outbound H2 search arms.
# Same-thread refs duplicate context the drafter already has via the
# inbound body's quoted-history chain. Set to '0' to disable the filter
# (pre-222 behavior — surfaces same-thread refs).
# RAG_RETRIEVE_EXCLUDE_SAME_THREAD=1
# ── MAILBOX_LOCAL_MODEL_OVERRIDE — local-model A/B knob ────────────────
# Set to an Ollama model tag (e.g., `qwen3.5:4b-ctx4k`, `gemma4:e4b-q4`)
# to swap the local-route draft model. Honored in
# dashboard/lib/drafting/router.ts pickEndpoint(). Cloud route is
# unaffected by this knob.
#
# Purpose: 2-week local-vs-local A/B shadow experiment. Strategic
# direction is local-first appliance; this knob lets us measure whether
# a newer/better local model meaningfully improves operator approval
# rate vs. the baseline `qwen3:4b-ctx4k`. See plan:
# ~/.claude/plans/could-mailbox-realistically-live-shimmering-bubble.md
#
# Pre-flight: pull the override model on the appliance first
#   ssh mailbox2 'docker exec mailbox-ollama-1 ollama pull qwen3.5:4b'
# Confirm the tag matches Ollama's local list before flipping the flag —
# a missing model 404s every draft call until the env var is reverted.
#
# Rollback: remove this line and `docker compose up -d mailbox-dashboard`
# (NOT `restart` — see root CLAUDE.md ".env rotation gotchas").
# MAILBOX_LOCAL_MODEL_OVERRIDE=qwen3.5:4b-ctx4k

# ── Gmail credentials ──────────────────────────────────────────────────
# Provisioned via the n8n Gmail OAuth flow on the appliance — no env
# var needed here. The OAuth refresh token lives in n8n's encrypted
# credential store (POSTGRES + N8N_ENCRYPTION_KEY).
#
# If you ever fall back to IMAP/SMTP (not the active path):
# IMAP_HOST=imap.gmail.com
# IMAP_USER=operator@example.com
# IMAP_PASSWORD=changeme_imap_app_specific_password
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=operator@example.com
# SMTP_PASSWORD=changeme_smtp_app_specific_password
