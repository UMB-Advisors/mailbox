# Postgres
POSTGRES_USER=mailbox
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=mailbox

# n8n
N8N_ENCRYPTION_KEY=changeme_n8n_encryption_key

# Anthropic (for Phase 2+)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama image (resolve via: jetson-containers autotag ollama)
OLLAMA_IMAGE=dustynv/ollama:0.18.4-r36.4-cu126-22.04

# --- Dashboard backend (Phase 2) ---
DASHBOARD_PORT=3000
# Composed at runtime by docker-compose dashboard service environment block:
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# --- Classification routing (Phase 2, D-02) ---
ROUTING_LOCAL_CONFIDENCE_FLOOR=0.75

# --- Anthropic (Phase 2) ---
# Pooled Glue Co key — customer is billed at cost + 20%
ANTHROPIC_API_KEY=
