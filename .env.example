# MailBOX Zero — appliance environment template
# Copy to .env and fill in real values before `docker compose up -d`.
# Variables marked REQUIRED must be set; commented blocks are optional.

# ── Postgres (operational datastore) ────────────────────────────────────
POSTGRES_USER=mailbox
POSTGRES_PASSWORD=changeme_postgres_password   # REQUIRED
POSTGRES_DB=mailbox

# ── n8n (workflow runtime) ──────────────────────────────────────────────
# Encryption key for n8n's stored credentials. Treat as a secret.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme_n8n_encryption_key   # REQUIRED

# ── Caddy (public HTTPS) ────────────────────────────────────────────────
# Public hostname for this appliance (the site address Caddy serves).
# Substituted into the Caddyfile via {$DOMAIN}. Without this, Caddy
# crashes with an empty site address. STAQPRO-237.
DOMAIN=mailbox.example.com   # REQUIRED — your appliance hostname

# Let's Encrypt account email — used for cert expiry warnings.
# Substituted into the Caddyfile global block via {$CADDY_EMAIL}.
# If left empty, certs still issue but you get no expiry warnings.
CADDY_EMAIL=ops@example.com   # REQUIRED for expiry warnings

# Cloudflare API token (DNS-edit scope only) for DNS-01 cert issuance.
CLOUDFLARE_API_TOKEN=changeme_cloudflare_dns_edit_token   # REQUIRED for public TLS

# ── Caddy basic_auth (STAQPRO-131) ──────────────────────────────────────
# Gates /dashboard/* and the n8n editor at root behind a single password.
# Generate a bcrypt hash with: docker run --rm caddy:2 caddy hash-password
# If left empty, the Caddyfile blocks proxy unauthenticated (current
# pre-#2 state — DO NOT ship to a 2nd customer like this).
MAILBOX_BASIC_AUTH_USER=admin
MAILBOX_BASIC_AUTH_HASH=

# ── Ollama image (PIN BY DIGEST — STAQPRO-240) ─────────────────────────
# Always pin to a specific digest (sha256), not a moving tag. Upstream
# `ollama/ollama:latest` is a moving target; bumps to a Qwen3-thinking-mode
# release (e.g. 0.23.0) silently broke classification on customer #2 in
# Session 3 of the v0.2 install. The fix shipped in n8n MailBOX-Classify
# (`think: false`) protects against the regression but is not a substitute
# for pinning the runtime.
#
# Capture the live digest on a healthy appliance:
#   docker inspect mailbox-ollama-1 --format '{{.Image}}'
# Then resolve to the repo digest:
#   IID=$(docker inspect mailbox-ollama-1 --format '{{.Image}}')
#   docker inspect "$IID" --format '{{range .RepoDigests}}{{.}}{{println}}{{end}}'
#
# Current customer #1 / #2 baselines (2026-05-07):
#   M1 (Heron Labs): ollama/ollama@sha256:662109db8037f17257cfc6e816289c0d4c9ae8a2a4ff760b653d8d410e234ba0  (0.20.5)
#   M2 (staqs.io):   ollama/ollama@sha256:5600a652d1081050f398152127c584222546354491f27fe47ccbc6351bc870bd  (0.23.0)
#
# For new appliances: pin to whichever validated digest you're cloning from.
# The `dustynv/ollama:0.18.4-r36.4-cu126-22.04` reference in CLAUDE.md
# "Core Technologies" is a documented but unused alternative — the live
# fleet runs upstream `ollama/ollama` images, which work on JetPack 6.2
# with nvidia-container-toolkit configured.
OLLAMA_IMAGE=ollama/ollama@sha256:5600a652d1081050f398152127c584222546354491f27fe47ccbc6351bc870bd

# ── Anthropic (alt-cloud fallback for drafting; not used by default) ────
# 02-07 cloud path now goes through Ollama Cloud — see below.
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Ollama Cloud (cloud-escalation drafting target) ─────────────────────
# Same /api/chat surface as the local Ollama daemon. Used when classify
# routes a message to "cloud" (escalate, low-confidence). Get a key at
# https://ollama.com/cloud. Empty key = cloud path will fail; local-only.
OLLAMA_CLOUD_API_KEY=
# Override base URL or default model if needed:
# OLLAMA_CLOUD_BASE_URL=https://ollama.com
# OLLAMA_CLOUD_MODEL=gpt-oss:120b

# ── Gmail credentials ──────────────────────────────────────────────────
# Provisioned via the n8n Gmail OAuth flow on the appliance — no env
# var needed here. The OAuth refresh token lives in n8n's encrypted
# credential store (POSTGRES + N8N_ENCRYPTION_KEY).
#
# If you ever fall back to IMAP/SMTP (not the active path):
# IMAP_HOST=imap.gmail.com
# IMAP_USER=operator@example.com
# IMAP_PASSWORD=changeme_imap_app_specific_password
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=operator@example.com
# SMTP_PASSWORD=changeme_smtp_app_specific_password
